# ── Required ──────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
NOTION_API_KEY=ntn_your-notion-api-key
NOTION_DATABASE_ID=your-notion-database-id
MCP_SERVER_URL=https://mcp.your-product.com

# ── Branding (optional) ──────────────────────────────────────────────
BOT_NAME=Help Bot
PRODUCT_NAME=Your Product

# ── OAuth (optional — defaults work for most MCP servers) ────────────
# OAUTH_CLIENT_ID=claude
# OAUTH_REDIRECT_URI=https://claude.ai/oauth/callback
# OAUTH_SCOPES=mcp.read mcp.write
# MCP_HELP_URL=https://docs.your-product.com/mcp-setup

# ── RAG tuning (optional) ────────────────────────────────────────────
# RAG_TOP_K=8
# CLAUDE_MODEL=claude-sonnet-4-5-20250929

# ── Deployment (optional) ────────────────────────────────────────────
# DATA_DIR=/var/data
